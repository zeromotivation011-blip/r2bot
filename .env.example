# R2BOT environment variables
# Copy this file to .env.local for local dev, and set these in Vercel for production.
# NEVER commit .env.local to git.

# ---- Anthropic (R2 Co-pilot brain) ----
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ---- Supabase (database, auth) ----
# Project: bxgtocghjypbomszwvfr (r2bot)
NEXT_PUBLIC_SUPABASE_URL=https://bxgtocghjypbomszwvfr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_mOWKOHsS6qxUXnPI4D9g0Q_rPxDI0oj
SUPABASE_SERVICE_ROLE_KEY=

# ---- OpenAI embeddings (powers RAG on the R2 Co-pilot) ----
# Without this, /api/copilot still works but can't ground answers in the Atlas.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---- Resend (newsletter, transactional email) ----
# Will be wired in v1.0. Get a key at https://resend.com
RESEND_API_KEY=

# ---- Razorpay (Pro tier payments — ₹799/mo, ₹5,999/yr) ----
# Get keys from https://dashboard.razorpay.com/app/keys
# KEY_ID is safe to expose to the browser (used by Razorpay Checkout JS).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
